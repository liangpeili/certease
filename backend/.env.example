# 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/ssl_manager?schema=public"

# Redis（BullMQ 队列）
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# 加密（用于加密 DNS 凭据和私钥）
ENCRYPTION_KEY="your-32-byte-encryption-key-change-this-in-production"

# 服务器
PORT=3001
NODE_ENV="development"

# 前端 URL（CORS）
FRONTEND_URL="http://localhost:3000"

# 邮件服务（可选）
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ACME 环境（staging 或 production）
ACME_ENVIRONMENT="staging"
